{
  "manifest_version": 3,
  "name": "reels-catcher",
  "version": "0.1.0",
  "description": "Passively captures Instagram DM reel URLs and forwards them to a local reels-catcher API.",
  "permissions": [
    "storage",
    "scripting",
    "debugger",
    "tabs"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/direct/*"
      ],
      "js": [
        "page-interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.instagram.com/direct/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-interceptor.js"
      ],
      "matches": [
        "https://www.instagram.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
